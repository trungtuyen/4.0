rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tuyenthcskimhy@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Teachers
    function isValidTeacher(data) {
      return data.keys().hasAll(['id', 'name', 'username', 'email', 'school', 'level', 'status']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.status in ['active', 'inactive'];
    }

    match /teachers/{teacherId} {
      allow read: if true; // Public for login lookups
      allow create: if true; // Public registration
      allow update, delete: if isAdmin() || isOwner(teacherId);
    }

    // 2. Categories
    function isValidCategory(data) {
      return data.keys().hasAll(['title', 'authorId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.authorId is string && data.authorId.size() <= 128;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidCategory(incoming());
      allow update: if (isAdmin() || isOwner(existing().authorId)) && isValidCategory(incoming());
      allow delete: if isAdmin() || isOwner(existing().authorId);
    }

    // 3. Wall Posts
    function isValidWallPost(data) {
      return data.keys().hasAll(['categoryId', 'imageSrc', 'studentName']) &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.studentName is string && data.studentName.size() <= 100 &&
             data.imageSrc is string && data.imageSrc.size() <= 1048576; // 1MB limit for base64
    }

    match /wall_posts/{postId} {
      allow read: if true;
      allow create: if isValidWallPost(incoming()) && 
                    (!incoming().keys().contains('score')) &&
                    (!incoming().keys().contains('comments'));
      
      allow update: if (
        // Action: Score
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['score']) && incoming().score is number) ||
        // Action: Comment
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['comments']) && incoming().comments is list) ||
        isAdmin()
      );
      
      allow delete: if isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/categories/$(existing().categoryId)) && get(/databases/$(database)/documents/categories/$(existing().categoryId)).data.authorId == request.auth.uid);
    }

    // 4. Exams
    match /exams/{examId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().teacherId);
    }

    // 5. Classes
    match /classes/{classId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().teacherId);
    }

    // 6. Students
    match /students/{studentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner(existing().teacherId);
    }

    // 7. Results
    match /results/{resultId} {
      allow read: if true;
      allow create: if true; // Students can submit results
      allow update, delete: if isAdmin();
    }

    // 8. Exam Sessions
    match /exam_sessions/{sessionId} {
      allow read, write: if isSignedIn() || isAdmin();
    }
  }
}
